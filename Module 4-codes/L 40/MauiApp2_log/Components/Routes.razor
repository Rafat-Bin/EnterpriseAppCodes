@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Navigation
@inject IJSRuntime JS

<Router AppAssembly="typeof(MauiProgram).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>

@code {
    protected override async Task OnInitializedAsync()
    {
        var token = await SecureStorage.Default.GetAsync("authToken");
        var target = string.IsNullOrEmpty(token) ? "/login" : "/";

        var currentPath = new Uri(Navigation.Uri).AbsolutePath;

        if (!string.Equals(currentPath, target, StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo(target);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = Preferences.Default.Get("AppTheme", "Light");
            await JS.InvokeVoidAsync("applyTheme", theme);
        }
    }
}